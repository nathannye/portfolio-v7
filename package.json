{
  "name": "thumper",
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "^1.3.11",
    "@types/node": "^25.5.2",
    "turbo": "^2.9.4",
    "typescript": "^6.0.2"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "bun@1.3.8",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
