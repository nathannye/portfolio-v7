{
  "name": "thumper",
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": "24"
  },
  "packageManager": "bun@1.3.8",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
